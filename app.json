{
  "expo": {
    "name": "routinmate",
    "slug": "routinmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon(1).png",
    "scheme": "routinmate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.routinmate.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Yakınındaki mate'leri bulmak ve teslimat adresi için konumuna ihtiyacımız var.",
        "NSLocationAlwaysUsageDescription": "Yakınındaki mate'leri bulmak için konumuna ihtiyacımız var."
      },
      "config": {
        "googleMapsApiKey": "$(EXPO_PUBLIC_GOOGLE_MAPS_KEY)"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon(1).png",
        "backgroundColor": "#00bf63"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.routinmate.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "$(EXPO_PUBLIC_GOOGLE_MAPS_KEY)"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#00bf63",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/routinemate (1).png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5fdaaed-b3d8-490e-9a1e-b32dafedaa1e"
      }
    },
    "owner": "routinmates-organization"
  }
}
